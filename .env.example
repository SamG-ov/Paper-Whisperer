# Copy this file to ".env" and fill in your real values.
# The real .env is git-ignored and must NEVER be committed.

# Google Gemini API key — get one free at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-gemini-api-key-here

# Optional: LangSmith tracing for observability (free at https://smith.langchain.com).
# When enabled, every chain run is auto-traced — no code changes needed.
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=your-langsmith-key
# LANGSMITH_PROJECT=paperwhisperer
